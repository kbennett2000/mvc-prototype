# Copy this file to .env.local for local development.
# Set these in your Vercel project → Settings → Environment Variables for production.
#
# .env.local is gitignored and will never be committed. Never put real secrets in
# .env.local.example — this file IS committed and visible to everyone.

# ── Resend (form email delivery) ───────────────────────────────────────────────
# Get your API key at resend.com (free tier is more than enough for a small church).
RESEND_API_KEY=re_your_key_here

# The "From" address for notification emails. Must be on a domain you've verified
# in Resend. Use "onboarding@resend.dev" for initial testing before domain setup.
RESEND_FROM_EMAIL=noreply@yourchurch.com

# The church's email inbox that receives form submissions.
# Should match the email in content/site.json → church.email.
CHURCH_EMAIL=hello@yourchurch.com

# ── TinaCMS / TinaCloud (CMS admin auth) ───────────────────────────────────────
# Get these from https://app.tina.io after creating a project for your church.
# NEXT_PUBLIC_ prefix makes this value available in the browser (needed by TinaCMS).
NEXT_PUBLIC_TINA_CLIENT_ID=your_tina_client_id_here
TINA_TOKEN=your_tina_token_here

# -----------------------------------------------------------------------------
# Custom admin pages — sign-in
# -----------------------------------------------------------------------------
# These protect /admin/devotionals, /admin/digest, and /api/admin/* — the
# custom pages built into the site. They do NOT affect TinaCMS at /admin/
# (TinaCloud has its own collaborator list).
#
# WHICH ONE TO USE: see /content/site.json → adminAuth.provider.
#   "basic"  → only ADMIN_PASSWORD below is required.
#   "google" → the GOOGLE_*, NEXTAUTH_*, and (optionally) ADMIN_ALLOWLIST
#              vars below are required; ADMIN_PASSWORD is ignored.
# Switch providers in Site Settings → Admin Authentication and redeploy.

# --- Shared-password (Basic Auth) --------------------------------------------
# Long random string. Generate with: openssl rand -base64 32
ADMIN_PASSWORD=

# --- Google sign-in (NextAuth / Auth.js v5) ----------------------------------
# Credentials from Google Cloud Console → APIs & Services → Credentials →
# "OAuth 2.0 Client ID" (Web application).
# Authorized redirect URI: https://YOUR-DOMAIN/api/auth/callback/google
# For local dev also add: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL the site is served from. http://localhost:3000 for dev,
# the production domain (https://yourchurch.org) on Vercel.
NEXTAUTH_URL=http://localhost:3000

# Comma-separated emails granted admin access on top of the CMS allowlist.
# Use this for the initial bootstrap (the CMS allowlist starts empty —
# you can't add yourself to it until you can sign in to the CMS, and
# you can't sign in to the CMS until you're on the allowlist).
# Set it, sign in, add your real entry in the CMS, then remove this var.
ADMIN_ALLOWLIST=
