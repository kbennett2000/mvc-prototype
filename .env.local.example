# TinaCMS — get these from app.tina.io after connecting your repo
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=

# Resend — get your API key from resend.com
RESEND_API_KEY=

# The "from" address for outbound emails (must be a verified domain/address in Resend)
RESEND_FROM_EMAIL=

# The church inbox that receives contact/prayer/visit form submissions
CHURCH_EMAIL=
