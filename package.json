{
  "name": "church-site-template",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source Next.js + Decap CMS starter for small churches. Editors update content in the browser. Free hosting on Vercel.",
  "keywords": [
    "church",
    "church-website",
    "website",
    "template",
    "starter",
    "nextjs",
    "next-js",
    "react",
    "tailwind",
    "tailwindcss",
    "cms",
    "decap-cms",
    "netlify-cms",
    "nonprofit",
    "ministry",
    "static-site"
  ],
  "license": "MIT",
  "author": "Church Site Template contributors",
  "homepage": "https://github.com/your-org/your-repo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/your-repo.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/your-repo/issues"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "start": "node scripts/dev.js",
    "cms": "tinacms dev -c \"next dev\"",
    "deploy": "node scripts/deploy-setup.js",
    "doctor": "node scripts/doctor.js",
    "dev": "next dev",
    "build": "tinacms build && next build",
    "server": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tinacms/cli": "^1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.453.0",
    "marked": "^18.0.3",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^4",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "tinacms": "^2"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  }
